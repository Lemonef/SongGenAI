sequenceDiagram
    actor Creator
    participant Browser
    participant GenController as GenerationController
    participant GenService as GenerationService
    participant Factory as StrategyFactory
    participant MockStrategy as MockSongGeneratorStrategy
    participant SunoStrategy as SunoSongGeneratorStrategy
    participant SunoAPI as Suno AI API
    participant DB as SQLite DB
    participant BgThread as Background Thread

    Creator->>Browser: Fill form (prompt, genre, mood, title, duration)
    Browser->>GenController: POST /generation/create/

    GenController->>DB: Validate Creator profile
    GenController->>DB: Create Form record
    GenController->>DB: Check credit_balance > 0

    alt Insufficient credits
        GenController-->>Browser: JSON { status: error, message: no credits }
    else Credits OK
        GenController->>GenService: generate_song_from_form(form, use_mock)

        alt use_mock = True
            GenService->>MockStrategy: generate(form)
            MockStrategy->>DB: Create Song (status=SUCCESS, placeholder audio_url)
            MockStrategy->>DB: Create CreditTransaction (DEDUCT, amount=1)
            MockStrategy-->>GenService: Return Song
            GenService-->>GenController: Return Song
            GenController-->>Browser: JSON { song_id, status: SUCCESS, audio_url }

        else use_mock = False
            GenService->>Factory: get_generator_strategy()
            Factory-->>GenService: SunoSongGeneratorStrategy

            GenService->>SunoStrategy: generate(form)
            SunoStrategy->>SunoAPI: POST /api/v1/generate { prompt, style, callBackUrl }

            alt Connection error
                SunoAPI-->>SunoStrategy: Timeout / refused
                SunoStrategy-->>GenController: raise SunoOfflineError
                GenController-->>Browser: JSON { status: suno_offline }

            else Insufficient Suno credits
                SunoAPI-->>SunoStrategy: 402 or code=429
                SunoStrategy-->>GenController: raise SunoInsufficientCreditsError
                GenController-->>Browser: JSON { status: suno_no_credits }

            else Success
                SunoAPI-->>SunoStrategy: { task_id }
                SunoStrategy->>DB: Create Song (status=PENDING, task_id)
                SunoStrategy->>DB: Create CreditTransaction (DEDUCT, amount=1)
                SunoStrategy->>BgThread: spawn _poll_until_done(song)
                SunoStrategy-->>GenService: Return Song (PENDING)
                GenService-->>GenController: Return Song
                GenController-->>Browser: JSON { song_id, status: PENDING, task_id }
            end
        end
    end

    %% Client polls for status
    loop Every few seconds (frontend JS)
        Browser->>GenController: GET /generation/status/<song_id>/
        GenController->>DB: Fetch Song by id
        GenController-->>Browser: JSON { status, audio_url, duration_seconds }
        alt status = SUCCESS
            Browser->>Creator: Show audio player
        end
    end

    %% Background thread polls Suno
    loop Every 5s, max 60 polls
        BgThread->>SunoAPI: GET /api/v1/generate/record-info?taskId=...
        SunoAPI-->>BgThread: { status, audioUrl, imageUrl, duration }
        BgThread->>DB: Update Song (status, audio_url, image_url, duration_seconds)
        alt status = SUCCESS or FAILED
            BgThread->>BgThread: Exit loop
        end
        alt max polls exceeded
            BgThread->>DB: Update Song (status=FAILED)
        end
    end

    %% Suno webhook callback
    SunoAPI->>GenController: POST /generation/suno/callback/
    GenController->>DB: Find Song by task_id
    alt audio_url found in payload
        GenController->>DB: Update Song (audio_url, status=SUCCESS)
    else FAILED in payload
        GenController->>DB: Update Song (status=FAILED)
    end
    GenController-->>SunoAPI: JSON { song_id }
