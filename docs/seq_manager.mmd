sequenceDiagram
    actor Creator
    participant Browser
    participant ManagerController as SongManagerController
    participant ManagerService as SongManagerService
    participant DB as SQLite DB

    %% Song History
    Creator->>Browser: Open Song Manager
    Browser->>ManagerController: GET /manager/
    ManagerController-->>Browser: Render manager/index.html

    Browser->>ManagerController: GET /manager/history/
    ManagerController->>ManagerService: get_creator_song_history(creator)
    ManagerService->>DB: Song.filter(creator).order_by(-created_at)
    ManagerService-->>ManagerController: QuerySet of Songs
    ManagerController-->>Browser: JSON { songs[] }

    %% Library Management
    Creator->>Browser: Create new library
    Browser->>ManagerController: POST /manager/library/create/ { name }
    ManagerController->>DB: Library.objects.create(profile, name)
    ManagerController-->>Browser: JSON { library_id, name }

    Creator->>Browser: Add song to library
    Browser->>ManagerController: POST /manager/library/<id>/add-song/<song_id>/
    ManagerController->>ManagerService: add_song_to_library(library_id, song_id)
    ManagerService->>DB: library.songs.add(song)
    ManagerController-->>Browser: JSON { success }

    Creator->>Browser: Remove song from library
    Browser->>ManagerController: POST /manager/library/<id>/remove-song/<song_id>/
    ManagerController->>ManagerService: remove_song_from_library(library_id, song_id)
    ManagerService->>DB: library.songs.remove(song)
    ManagerController-->>Browser: JSON { success }

    Creator->>Browser: Delete library
    Browser->>ManagerController: POST /manager/library/<id>/delete/
    ManagerController->>DB: Library.delete()
    ManagerController-->>Browser: JSON { success }

    %% Share Management
    Creator->>Browser: Create share link for song
    Browser->>ManagerController: POST /manager/song/<id>/share/
    ManagerController->>ManagerService: create_share_for_song(song_id)
    ManagerService->>DB: Share.objects.create(song, token=uuid4)
    ManagerController-->>Browser: JSON { share_link: /manager/share/<token>/ }

    Creator->>Browser: View song shares
    Browser->>ManagerController: GET /manager/song/<id>/shares/
    ManagerController->>ManagerService: get_song_shares(song_id)
    ManagerService->>DB: song.shares.all()
    ManagerController-->>Browser: JSON { shares[] }

    Creator->>Browser: Delete share
    Browser->>ManagerController: POST /manager/share/<id>/delete/
    ManagerController->>ManagerService: delete_share(share_id)
    ManagerService->>DB: Share.delete()
    ManagerController-->>Browser: JSON { success }

    %% Open shared song (public, no login required)
    actor Listener
    Listener->>Browser: Visit /manager/share/<token>/
    Browser->>ManagerController: GET /manager/share/<token>/
    ManagerController->>ManagerService: get_share_by_token(token)
    ManagerService->>DB: Share.objects.get(token=token)
    ManagerController-->>Browser: JSON { song metadata }

    %% Visibility Toggle
    Creator->>Browser: Toggle song public/private
    Browser->>ManagerController: POST /manager/song/<id>/toggle-visibility/
    ManagerController->>DB: song.is_public = not song.is_public
    ManagerController-->>Browser: JSON { is_public }
