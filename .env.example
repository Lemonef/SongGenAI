# Song generation strategy: "mock" (offline) or "suno" (calls Suno API)
GENERATOR_STRATEGY=your_strategy_here

# Required only when GENERATOR_STRATEGY=suno
SUNO_API_KEY=your_suno_api_key_here
SUNO_CALLBACK_URL=https://your-ngrok-url/generation/suno/callback/

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
